# ============================================================
# Variáveis de ambiente do Robô Comparativo MultiA
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- MultiA Mais ---
MULTIA_MAIS_BASE_URL=https://api.infoel.info
MULTIA_MAIS_ORIGIN=https://multiamais.infoel.info
MULTIA_MAIS_REFERER=https://multiamais.infoel.info/
MULTIA_MAIS_AUTHORIZATION=Basic SEU_TOKEN_BASE64_AQUI
MULTIA_MAIS_LOGIN=seu_login@multiamais.com.br
MULTIA_MAIS_SENHA=sua_senha
MULTIA_MAIS_JWT=seu_jwt_token

# --- MultiA Avaliações ---
MULTIA_AVALIACOES_BASE_URL=https://api.infoel.info
MULTIA_AVALIACOES_ORIGIN=https://multia.infoel.info
MULTIA_AVALIACOES_REFERER=https://multia.infoel.info/
MULTIA_AVALIACOES_AUTHORIZATION=Basic SEU_TOKEN_BASE64_AQUI
MULTIA_AVALIACOES_LOGIN=seu_login@multiavaliacao.com.br
MULTIA_AVALIACOES_SENHA=sua_senha
MULTIA_AVALIACOES_JWT=seu_jwt_token

# --- Certificados digitais (.pfx) ---
CERT_PASSWORD=senha_dos_certificados
CERT_PESSOA_MAIS=leandro.pfx
CERT_EMPRESA_MAIS=multia_mais.pfx
CERT_PESSOA_AVAL=matheus.pfx
CERT_EMPRESA_AVAL=multia_avaliacoes.pfx
